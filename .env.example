# Supabase PostgreSQL bağlantı dizesi
# Supabase Dashboard → Settings → Database → Connection string bölümünden al
DEFAULT_CONNECTION=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# AI - Groq LLaMA API
GROQ_API_KEY=your_groq_api_key_here

# Job scraper API'leri — key gerekli
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
JOOBLE_API_KEY=your_jooble_api_key_here
SERPAPI_KEY=your_serpapi_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# Job scraper API'leri — opsiyonel (boş bırakılabilir, ücretsiz tier çalışır)
FINDWORK_API_KEY=your_findwork_api_key_here
# Reed.co.uk — https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=your_reed_api_key_here
# USAJobs — https://developer.usajobs.gov/APIRequest/Index
USAJOBS_API_KEY=your_usajobs_api_key_here
USAJOBS_EMAIL=your_email@example.com

# Iyzico ödeme
# Sandbox hesabı: https://sandbox-merchant.iyzipay.com
IYZICO_API_KEY=sandbox-your_api_key
IYZICO_SECRET_KEY=sandbox-your_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Callback URL (local test için ngrok: ngrok http 5109)
IYZICO_CALLBACK_URL=https://YOUR_NGROK_URL/Payment/Callback
