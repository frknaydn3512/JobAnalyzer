@page
@model ListingsModel
@{
    ViewData["Title"] = "İş İlanları";
}

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary mb-0"><i class="bi bi-card-list"></i> Piyasada Neler Var?</h2>
        <div class="d-flex gap-2">
            <span class="badge bg-primary fs-6"><i class="bi bi-building"></i> @Model.TotalSirketCount Şirket</span>
            <span class="badge bg-warning text-dark fs-6"><i class="bi bi-person-workspace"></i> @Model.TotalFreelanceCount Freelance</span>
            <span class="badge bg-secondary fs-6">Toplam @Model.TotalItems</span>
        </div>
    </div>

    @* Arama ve Filtre Kartı *@
    <div class="card p-4 shadow-sm mb-4 border-0 bg-light">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-7">
                <input type="text" asp-for="SearchTerm" class="form-control form-control-lg"
                       placeholder="Teknoloji veya Başlık Ara (Örn: React, C#, .NET)..." autocomplete="off">
            </div>
            <div class="col-md-3">
                <select asp-for="JobTypeFilter" class="form-select form-select-lg">
                    <option value="">🔍 Tüm İlanlar</option>
                    <option value="Şirket İlanı">🏢 Şirket İlanları</option>
                    <option value="Freelance İlanı">💼 Freelance İlanları</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-lg w-100"><i class="bi bi-search"></i> Ara</button>
            </div>
        </form>
    </div>

    @if (Model.Jobs != null && Model.Jobs.Any())
    {
        <div class="table-responsive bg-white shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 28%">İlan Başlığı</th>
                        <th style="width: 10%">Tür</th>
                        <th style="width: 47%">Aranan Yetenekler (AI Analizi)</th>
                        <th style="width: 15%" class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.Jobs)
                    {
                        bool isFreelance = job.JobType == "Freelance İlanı";
                        <tr>
                            <td class="fw-bold">
                                <a asp-page="/JobDetail" asp-route-id="@job.Id" class="text-decoration-none text-primary">
                                    @job.Title
                                </a>
                                @if (!string.IsNullOrEmpty(job.CompanyName) && job.CompanyName != "Freelance Müşteri" && job.CompanyName != "Daha Sonra Çekilecek")
                                {
                                    <br /><small class="text-muted fw-normal"><i class="bi bi-building"></i> @job.CompanyName</small>
                                }
                            </td>
                            <td>
                                @if (isFreelance)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-person-workspace"></i> Freelance
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">
                                        <i class="bi bi-building"></i> Şirket
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(job.ExtractedSkills))
                                {
                                    @foreach(var skill in job.ExtractedSkills.Split(','))
                                    {
                                        <span class="badge bg-info text-dark me-1 mb-1">@skill.Trim()</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">Henüz AI analizi yapılmadı.</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="/JobDetail" asp-route-id="@job.Id" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-info-circle"></i> Detay
                                </a>
                                <a href="@job.Url" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        <nav class="mt-4 fade-in" aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (Model.P > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="?SearchTerm=@Model.SearchTerm&JobTypeFilter=@Model.JobTypeFilter&P=@(Model.P - 1)">Önceki</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled"><a class="page-link">Önceki</a></li>
                }

                @for (int i = Math.Max(1, Model.P - 3); i <= Math.Min(Model.TotalPages, Model.P + 3); i++)
                {
                    <li class="page-item @(i == Model.P ? "active" : "")">
                        <a class="page-link" href="?SearchTerm=@Model.SearchTerm&JobTypeFilter=@Model.JobTypeFilter&P=@i">@i</a>
                    </li>
                }

                @if (Model.P < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="?SearchTerm=@Model.SearchTerm&JobTypeFilter=@Model.JobTypeFilter&P=@(Model.P + 1)">Sonraki</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled"><a class="page-link">Sonraki</a></li>
                }
            </ul>
        </nav>
    }
    else
    {
        <div class="alert alert-warning text-center shadow-sm py-4">
            <i class="bi bi-exclamation-triangle-fill fs-1 text-warning mb-2"></i><br/>
            <h4>Tüh! Eşleşme Bulunamadı.</h4>
            <p class="mb-0">"<strong>@Model.SearchTerm</strong>" kriterine uygun bir iş ilanı yok. Başka bir teknoloji aramayı dene.</p>
        </div>
    }
</div>

<style>
    .fade-in { animation: fadeIn 0.5s ease-in-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>