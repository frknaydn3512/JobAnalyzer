@page
@model ListingsModel
@{
    ViewData["Title"] = "İş İlanları";
    var isCard = Model.ViewMode == "card";
    string pageUrl(int pg) => $"?SearchTerm={Model.SearchTerm}&JobTypeFilter={Model.JobTypeFilter}&SourceFilter={Model.SourceFilter}&LocationFilter={Model.LocationFilter}&ViewMode={Model.ViewMode}&P={pg}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-primary mb-0"><i class="bi bi-card-list"></i> Piyasada Neler Var?</h2>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-secondary fs-6">Toplam @Model.TotalItems</span>
        <span class="badge bg-primary fs-6"><i class="bi bi-building"></i> @Model.TotalSirketCount Şirket</span>
        <span class="badge bg-warning text-dark fs-6"><i class="bi bi-person-workspace"></i> @Model.TotalFreelanceCount Freelance</span>
        <!-- Görünüm Toggle -->
        <div class="btn-group btn-group-sm ms-2" role="group">
            <a href="?SearchTerm=@Model.SearchTerm&JobTypeFilter=@Model.JobTypeFilter&SourceFilter=@Model.SourceFilter&LocationFilter=@Model.LocationFilter&ViewMode=table&P=1"
               class="btn @(!isCard ? "btn-primary" : "btn-outline-secondary")"><i class="bi bi-list-ul"></i></a>
            <a href="?SearchTerm=@Model.SearchTerm&JobTypeFilter=@Model.JobTypeFilter&SourceFilter=@Model.SourceFilter&LocationFilter=@Model.LocationFilter&ViewMode=card&P=1"
               class="btn @(isCard ? "btn-primary" : "btn-outline-secondary")"><i class="bi bi-grid"></i></a>
        </div>
    </div>
</div>

<!-- Filtreler -->
<div class="card p-3 shadow-sm mb-4 border-0 bg-light">
    <form method="get" class="row g-2 align-items-end">
        <input type="hidden" name="ViewMode" value="@Model.ViewMode" />
        <div class="col-md-4">
            <input type="text" asp-for="SearchTerm" class="form-control"
                   placeholder="Teknoloji veya başlık ara..." autocomplete="off">
        </div>
        <div class="col-md-2">
            <select asp-for="JobTypeFilter" class="form-select">
                <option value="">Tüm Türler</option>
                <option value="Şirket İlanı">Şirket İlanı</option>
                <option value="Freelance İlanı">Freelance</option>
            </select>
        </div>
        <div class="col-md-2">
            <select asp-for="LocationFilter" class="form-select">
                <option value="">Tüm Konumlar</option>
                <option value="Remote">Remote / Uzaktan</option>
                <option value="Hybrid">Hibrit</option>
                <option value="Istanbul">İstanbul</option>
                <option value="Ankara">Ankara</option>
                <option value="Izmir">İzmir</option>
            </select>
        </div>
        <div class="col-md-3">
            <select asp-for="SourceFilter" class="form-select">
                <option value="">Tüm Kaynaklar</option>
                @foreach (var source in Model.AvailableSources)
                {
                    <option value="@source" selected="@(Model.SourceFilter == source)">@source</option>
                }
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
        </div>
    </form>
</div>

@if (Model.Jobs.Any())
{
    @if (!isCard)
    {
        <!-- Tablo Görünümü -->
        <div class="table-responsive bg-white shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:30%">İlan Başlığı</th>
                        <th style="width:10%">Kaynak</th>
                        <th style="width:12%">Konum</th>
                        <th style="width:33%">Yetenekler (AI)</th>
                        <th style="width:15%" class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.Jobs)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a asp-page="/JobDetail" asp-route-id="@job.Id" class="text-decoration-none text-primary">@job.Title</a>
                                @if (!string.IsNullOrEmpty(job.CompanyName) && job.CompanyName != "Bilinmiyor")
                                {
                                    <br /><small class="text-muted fw-normal"><i class="bi bi-building"></i> @job.CompanyName</small>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark border small">@job.Source</span></td>
                            <td><small class="text-muted"><i class="bi bi-geo-alt"></i> @job.Location</small></td>
                            <td>
                                @if (!string.IsNullOrEmpty(job.ExtractedSkills))
                                {
                                    @foreach (var skill in job.ExtractedSkills.Split(',').Take(5))
                                    {
                                        <span class="badge bg-info text-dark me-1 mb-1">@skill.Trim()</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">Analiz bekleniyor...</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="/JobDetail" asp-route-id="@job.Id" class="btn btn-sm btn-outline-secondary me-1">Detay</a>
                                <a href="@job.Url" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-box-arrow-up-right"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <!-- Kart Görünümü -->
        <div class="row g-3">
            @foreach (var job in Model.Jobs)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 p-3 fade-in">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-light text-dark border small">@job.Source</span>
                            @if (job.DateScraped >= DateTime.UtcNow.AddDays(-3))
                            {
                                <span class="badge bg-success">Yeni</span>
                            }
                        </div>
                        <h6 class="fw-bold mb-1">
                            <a asp-page="/JobDetail" asp-route-id="@job.Id" class="text-decoration-none text-dark">@job.Title</a>
                        </h6>
                        <p class="text-muted small mb-1"><i class="bi bi-building"></i> @job.CompanyName</p>
                        <p class="text-muted small mb-2"><i class="bi bi-geo-alt"></i> @job.Location</p>
                        @if (!string.IsNullOrEmpty(job.ExtractedSkills))
                        {
                            <div class="mb-3">
                                @foreach (var skill in job.ExtractedSkills.Split(',').Take(4))
                                {
                                    <span class="tech-badge">@skill.Trim()</span>
                                }
                            </div>
                        }
                        <div class="mt-auto d-flex gap-2">
                            <a asp-page="/JobDetail" asp-route-id="@job.Id" class="btn btn-sm btn-primary flex-grow-1">Detay</a>
                            <a href="@job.Url" target="_blank" class="btn btn-sm btn-outline-secondary"><i class="bi bi-box-arrow-up-right"></i></a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Sayfalama -->
    <nav class="mt-4" aria-label="Sayfalama">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.P <= 1 ? "disabled" : "")">
                <a class="page-link" href="@pageUrl(Model.P - 1)">Önceki</a>
            </li>
            @for (int i = Math.Max(1, Model.P - 3); i <= Math.Min(Model.TotalPages, Model.P + 3); i++)
            {
                <li class="page-item @(i == Model.P ? "active" : "")">
                    <a class="page-link" href="@pageUrl(i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.P >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@pageUrl(Model.P + 1)">Sonraki</a>
            </li>
        </ul>
    </nav>
}
else
{
    <div class="alert alert-warning text-center py-4">
        <i class="bi bi-exclamation-triangle-fill fs-1 text-warning mb-2 d-block"></i>
        <h5>Eşleşme bulunamadı</h5>
        <p class="mb-0">Farklı filtreler veya arama terimi dene.</p>
    </div>
}

<style>
    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
</style>
