@page
@model IndexModel
@{
    ViewData["Title"] = "Piyasa Analizi";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row mb-3">
    <div class="col-12">
        <h2 class="fw-bold text-primary"><i class="bi bi-bar-chart-line"></i> Yazılım Kariyer & Piyasa Radarı</h2>
        <p class="text-muted">Gerçek iş ilanlarından toplanan güncel piyasa trendleri.</p>
    </div>
</div>

<!-- Özet Metrikler -->
<div class="row g-3 mb-4 fade-in">
    <div class="col-6 col-md-3">
        <div class="card text-center p-3 border-0 shadow-sm h-100">
            <div class="display-5 fw-bold text-primary">@Model.TotalJobs.ToString("N0")</div>
            <div class="text-muted small mt-1">Toplam İlan</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3 border-0 shadow-sm h-100 bg-success bg-opacity-10">
            <div class="display-5 fw-bold text-success">+@Model.NewThisWeek</div>
            <div class="text-muted small mt-1">Bu Hafta Eklenen</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3 border-0 shadow-sm h-100 bg-info bg-opacity-10">
            <div class="display-5 fw-bold text-info">@Model.UniqueCompanies.ToString("N0")</div>
            <div class="text-muted small mt-1">Aktif Şirket</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3 border-0 shadow-sm h-100 bg-warning bg-opacity-10">
            <div class="display-5 fw-bold text-warning">@Model.AnalyzedJobs.ToString("N0")</div>
            <div class="text-muted small mt-1">AI Analiz Edildi</div>
        </div>
    </div>
</div>

<!-- CV CTA -->
<div class="card shadow-sm mb-4 border-0 bg-primary bg-opacity-10 fade-in">
    <div class="card-body d-flex align-items-center justify-content-between py-3 px-4">
        <div>
            <h5 class="fw-bold mb-1">CV'ni piyasaya göre analiz et!</h5>
            <p class="text-muted mb-0 small">Hangi skill'lerin eksik, hangi roller sana uygun — hepsini AI ile öğren.</p>
        </div>
        <a href="/CvAnalyzer" class="btn btn-primary shadow-sm ms-3 text-nowrap">
            <i class="bi bi-magic"></i> AI Analizi
        </a>
    </div>
</div>

<!-- Trend Grafiği (tam genişlik) -->
<div class="card shadow-sm p-4 mb-4 border-0 rounded-4 fade-in">
    <h5 class="fw-bold mb-1"><i class="bi bi-graph-up text-success"></i> Son 30 Gün — İlan Trendi</h5>
    <p class="text-muted small mb-3">Her gün kaç yeni ilan eklendi?</p>
    <div style="height: 200px;">
        <canvas id="trendChart"></canvas>
    </div>
</div>

<div class="row fade-in mb-4">
    <!-- Radar -->
    <div class="col-lg-5 mb-4 mb-lg-0">
        <div class="card shadow-sm p-4 h-100 border-0 rounded-4">
            <h5 class="fw-bold mb-1"><i class="bi bi-radar text-info"></i> Sektörel Yetenek Radarı</h5>
            <p class="text-muted small mb-3">Piyasadaki kategori yoğunlukları.</p>
            <div style="height: 280px; display:flex; justify-content:center; align-items:center;">
                <canvas id="radarChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Çalışma Modeli -->
    <div class="col-lg-4 mb-4 mb-lg-0">
        <div class="card shadow-sm p-4 h-100 border-0 rounded-4">
            <h5 class="fw-bold mb-1"><i class="bi bi-building text-warning"></i> Çalışma Modeli</h5>
            <p class="text-muted small mb-3">Remote / Hibrit / Ofis dağılımı.</p>
            <div style="height: 280px; display:flex; justify-content:center; align-items:center;">
                <canvas id="workModelChart"></canvas>
            </div>
        </div>
    </div>

    <!-- En Çok İlan Açan Şirketler -->
    <div class="col-lg-3">
        <div class="card shadow-sm p-4 h-100 border-0 rounded-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-trophy text-danger"></i> En Aktif Şirketler</h5>
            @foreach (var c in Model.TopCompanies)
            {
                var pct = Model.TopCompanies.Max(x => x.Count) > 0
                    ? (int)(c.Count * 100.0 / Model.TopCompanies.Max(x => x.Count))
                    : 0;
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-semibold text-truncate" style="max-width:140px" title="@c.Name">@c.Name</span>
                        <span class="text-muted">@c.Count</span>
                    </div>
                    <div class="progress" style="height:5px">
                        <div class="progress-bar bg-danger" style="width:@pct%"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Top Techs + Niche -->
<div class="row fade-in">
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm p-4 h-100 border-0 rounded-4">
            <h5 class="fw-bold mb-4"><i class="bi bi-fire text-danger"></i> En Çok Aranan Teknolojiler</h5>
            <div style="height: 320px;">
                <canvas id="topTechChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm p-4 h-100 border-0 rounded-4 bg-dark text-white">
            <h5 class="fw-bold mb-2 text-warning"><i class="bi bi-rocket-takeoff"></i> Yükselen Niş Yıldızlar</h5>
            <p class="small text-light opacity-75 mb-3">Top 10 dışında öne çıkan teknolojiler.</p>
            <div>
                @foreach (var tag in Model.NicheSkills)
                {
                    var size = Math.Max(12, Math.Min(28, 10 + (tag.Count / 5)));
                    <span class="badge rounded-pill bg-secondary bg-opacity-50 border border-light border-opacity-25 me-2 mb-2 p-2"
                          style="font-size:@(size)px;">
                        @tag.Name <small class="opacity-50">(@tag.Count)</small>
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    // Trend
    var trend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend));
    new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
            labels: trend.map(t => t.label),
            datasets: [{
                label: 'Yeni İlan',
                data: trend.map(t => t.count),
                borderColor: 'rgba(25,135,84,1)',
                backgroundColor: 'rgba(25,135,84,0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 3,
                borderWidth: 2
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
    });

    // Top Techs
    var topTech = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopTechs));
    new Chart(document.getElementById('topTechChart'), {
        type: 'bar',
        data: {
            labels: topTech.map(e => e.name),
            datasets: [{ label: 'İlan sayısı', data: topTech.map(e => e.count),
                backgroundColor: 'rgba(13,110,253,0.8)', borderRadius: 6 }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
    });

    // Radar
    var radar = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RadarData));
    new Chart(document.getElementById('radarChart'), {
        type: 'radar',
        data: {
            labels: ['Frontend', 'Backend', 'Database', 'DevOps/Cloud', 'Mobile'],
            datasets: [{ label: 'Piyasa Yoğunluğu', data: radar,
                backgroundColor: 'rgba(25,135,84,0.2)', borderColor: 'rgba(25,135,84,1)',
                pointBackgroundColor: 'rgba(25,135,84,1)', borderWidth: 2 }]
        },
        options: { responsive: true, maintainAspectRatio: false,
            scales: { r: { beginAtZero: true, ticks: { display: false } } } }
    });

    // Work Model
    var work = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WorkModelData));
    new Chart(document.getElementById('workModelChart'), {
        type: 'doughnut',
        data: {
            labels: ['Remote', 'Hibrit', 'Ofis'],
            datasets: [{ data: work,
                backgroundColor: ['rgba(13,202,240,0.8)', 'rgba(255,193,7,0.8)', 'rgba(108,117,125,0.8)'],
                borderWidth: 0, hoverOffset: 4 }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '65%',
            plugins: { legend: { position: 'bottom' } } }
    });
});
</script>

<style>
    .fade-in { animation: fadeIn 0.5s ease-in-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>
