@page
@model JobAnalyzer.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4 mt-4">
            <h3 class="mb-4 text-center fw-bold"><i class="bi bi-shield-lock text-primary"></i> Yeni Şifre Belirle</h3>

            @if (Model.ResetSuccess)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>
                    Şifreniz başarıyla değiştirildi!
                </div>
                <a href="/Account/Login" class="btn btn-primary w-100">Giriş Yap</a>
            }
            else
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Input.Email" />
                    <input type="hidden" asp-for="Input.Token" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Yeni Şifre</label>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="En az 8 karakter (büyük harf + özel karakter)" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Şifre Tekrar</label>
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-semibold">Şifremi Değiştir</button>
                </form>
            }

            <hr />
            <p class="text-center mb-0"><a href="/Account/Login">Giriş Yap</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
