@page
@model JobAnalyzer.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4 mt-4">
            <h3 class="mb-4 text-center fw-bold"><i class="bi bi-key text-warning"></i> Şifremi Unuttum</h3>

            @if (Model.EmailSent)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>
                    E-posta adresinize şifre sıfırlama bağlantısı gönderildi. Lütfen gelen kutunuzu kontrol edin.
                </div>
                <a href="/Account/Login" class="btn btn-primary w-100">Giriş Sayfasına Dön</a>
            }
            else
            {
                <p class="text-muted text-center mb-4">Kayıtlı e-posta adresinizi girin, size şifre sıfırlama bağlantısı göndereceğiz.</p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-posta</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="email@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-semibold">Sıfırlama Bağlantısı Gönder</button>
                </form>
            }

            <hr />
            <p class="text-center mb-0"><a href="/Account/Login">Giriş Yap</a> | <a href="/Account/Register">Kayıt Ol</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
