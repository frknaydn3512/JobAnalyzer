@page
@{
    ViewData["Title"] = "Ödeme İptal";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        <div class="display-1 text-warning mb-4">
            <i class="bi bi-x-circle-fill"></i>
        </div>
        <h2 class="fw-bold mb-3">Ödeme İptal Edildi</h2>
        <p class="text-muted fs-5 mb-4">
            Ödeme işlemi tamamlanmadı. Hesabınızdan herhangi bir ücret alınmamıştır.
        </p>
        <div class="d-flex gap-3 justify-content-center">
            <a href="/Pricing" class="btn btn-primary btn-lg">
                <i class="bi bi-arrow-left"></i> Planlara Dön
            </a>
            <a href="/" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-house"></i> Ana Sayfa
            </a>
        </div>
